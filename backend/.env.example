# Database
DATABASE_URL=sqlite+aiosqlite:///./career_engine.db
# For production (Supabase Session Pooler):
# DATABASE_URL=postgresql+asyncpg://<user>:<password>@<host>:5432/postgres

# LLM — Groq is PRIMARY (free), OpenAI is FALLBACK
GROQ_API_KEY=<your_groq_api_key>        # Free at https://console.groq.com
OPENAI_API_KEY=<your_openai_api_key>    # Optional fallback
LLM_PROVIDER=groq

# Telegram notifications (optional)
TELEGRAM_BOT_TOKEN=<your_telegram_bot_token>
TELEGRAM_CHAT_ID=<your_telegram_chat_id>

# Embeddings (runs locally, no API cost)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# App
APP_ENV=development
LOG_LEVEL=INFO
